# ─── App ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cittaa-counseling?retryWrites=true&w=majority

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@cittaa.in
RESEND_FROM_NAME=Cittaa Mind Bridge
EMAIL_FROM=notifications@cittaa.in

# ─── Cron (Session Reminders) ────────────────────────────────────────────────
# Set this secret and pass it as Bearer token when calling POST /api/sessions/reminders
CRON_SECRET=your-random-secret-for-cron-endpoint

# ─── Google Cloud Storage (RCI Report Uploads) ────────────────────────────────
GCS_BUCKET_NAME=cittaa-rci-reports
GCS_PROJECT_ID=your-gcloud-project-id
# Either provide keyfile path OR base64-encoded service account JSON
GCS_KEY_FILE=./gcs-service-account.json
# GCS_KEY_BASE64=<base64 encoded service account JSON> # For Railway env vars

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Cittaa Mind Bridge
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@cittaa.in
